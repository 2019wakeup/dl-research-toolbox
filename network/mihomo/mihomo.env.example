# Optional overrides used by scripts/mihomo-*.sh.
# Copy this file outside git-tracked paths or export variables in your shell.

MIHOMO_HOME="$HOME/.local/opt/mihomo"
MIHOMO_BIN_DIR="$HOME/.local/bin"
MIHOMO_CONFIG_DIR="$HOME/.config/mihomo"
MIHOMO_STATE_DIR="$HOME/.local/state/mihomo"
MIHOMO_LOG="$HOME/.local/state/mihomo/mihomo.log"
MIHOMO_PID_FILE="$HOME/.local/state/mihomo/mihomo.pid"

PROXY_HOST="127.0.0.1"
PROXY_PORT="7890"
